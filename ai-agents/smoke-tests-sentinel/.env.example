# SmokeSentinel — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to Git — it is in .gitignore

# ── REQUIRED ──────────────────────────────────────────────────
# Anthropic API key (LLM backbone for all agents)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Target URL for smoke tests (used when no --story provided)
TARGET_URL=https://your-app.example.com

# ── NOTIFICATIONS ─────────────────────────────────────────────
# Slack webhook for smoke result alerts
# Create at https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Slack channel for alerts (optional, overrides webhook default)
SLACK_CHANNEL=#smoke-alerts

# ── GITHUB INTEGRATION ────────────────────────────────────────
# GitHub token for PR comments (needs repo write)
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Repository slug (owner/repo) — used for PR comments
GITHUB_REPO=your-username/your-repo

# PR number (injected automatically by GitHub Actions)
GITHUB_PR_NUMBER=

# ── PLAYWRIGHT MCP SERVER ─────────────────────────────────────
# MCP server URL (local dev or Docker Compose sidecar)
MCP_SERVER_URL=http://localhost:3001

# ── LANGSMITH OBSERVABILITY (optional but recommended) ────────
# Enable tracing to observe agent reasoning step by step
# Get your key at https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=smokesentinel

# ── SMOKESENTINEL CONFIG ──────────────────────────────────────
# Default environment (staging or production)
SMOKE_ENV=staging

# Max duration in ms for the full smoke run (default 5 min)
SMOKE_MAX_DURATION_MS=300000

# Max duration per individual test (default 30s)
SMOKE_TEST_TIMEOUT_MS=30000
