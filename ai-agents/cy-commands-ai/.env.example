# --- Fournisseur LLM (au moins un des deux) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=anthropic            # "anthropic" ou "openai"
AI_MODEL=claude-sonnet-4-6       # ou "gpt-4o-mini" si AI_PROVIDER=openai

# --- LangSmith (observabilité/traçage des appels agent — recommandé) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cy-commands-box

# --- Cible des tests ---
CYPRESS_BASE_URL=http://localhost:4173
