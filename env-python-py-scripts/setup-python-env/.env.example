# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  .env.example — dev-setup-kit                                            ║
# ║  Copy to .env and fill in your values. Never commit .env.               ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Ollama — local LLM server ─────────────────────────────────────────────────
# URL of the Ollama server (default: local Docker service)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for fix suggestions
# Available after: ollama pull <model>
# Recommended: mistral | llama3.2 | codellama | phi3 | gemma2
OLLAMA_MODEL=mistral

# ── Python installer ──────────────────────────────────────────────────────────
# Target Python version for the Docker image build
# Override at build time: docker build --build-arg PYTHON_VERSION=3.14 .
PYTHON_VERSION=3.14

# ── Optional: override Ollama keep-alive (default 24h) ───────────────────────
# OLLAMA_KEEP_ALIVE=24h
